// This schema is an example consumers copy into their own schema.prisma.
// The package does not ship its own migrations.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model ApiKey {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  environment   String
  prefix        String   @unique
  hash          String
  pepperVersion Int      @default(1)
  scopes        String[]
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  revokedAt     DateTime?
  createdBy     String?
  createdAt     DateTime @default(now())

  @@index([tenantId, environment])
  @@index([tenantId, revokedAt])
}
